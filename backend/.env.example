# MongoDB connection settings
# IMPORTANT: Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/biometric_attendance
MONGODB_DB=biometric_attendance

# JWT configuration
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_32_chars_minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin bootstrap credentials
# Change these in production!
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# CORS and frontend settings
# Update these with your actual deployed URLs
ORIGINS=https://your-frontend-url.vercel.app,http://localhost:5173
FRONTEND_URL=https://your-frontend-url.vercel.app
ORIGIN=https://your-backend-url.onrender.com
BACKEND_URL=https://your-backend-url.onrender.com

# WebAuthn settings
# Update with your frontend domain
RP_ID=your-frontend-url.vercel.app
RP_NAME=Biometric Attendance System
